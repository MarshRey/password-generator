---
export interface Props {
  client: string;
  adSlot: string;
  format?: 'auto' | 'rectangle' | 'vertical' | 'horizontal';
  className?: string;
}

const { client, adSlot, format = 'auto', className = '' } = Astro.props;

const formatMap: Record<string, string> = {
  auto: 'auto',
  rectangle: 'rectangle',
  vertical: 'vertical',
  horizontal: 'horizontal',
};
---

<div class={`adsense-unit ${className}`}>
  <ins
    class="adsbygoogle"
    style="display:block; text-align:center;"
    data-ad-client={client}
    data-ad-slot={adSlot}
    data-ad-format={formatMap[format] ?? 'auto'}
    data-full-width-responsive="true"
  ></ins>
  <script is:inline>
    (function () {
      if (typeof window.adsbygoogle === 'undefined') return;
      var ads = document.querySelectorAll('.adsense-unit ins.adsbygoogle');
      ads.forEach(function (ad) {
        if (!ad.dataset.loaded) {
          ad.dataset.loaded = 'true';
          window.adsbygoogle.push({});
        }
      });
    })();
  </script>
</div>
