---
export interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, canonical, image, jsonLd } = Astro.props;
const site = Astro.site?.toString().replace(/\/$/, '') ?? 'https://example.com';
const pageUrl = canonical ?? `${site}${Astro.url.pathname}`;
const ogImage = image ?? `${site}/favicon.svg`;
const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT;
const ga4Id = import.meta.env.PUBLIC_GA4_ID;

const jsonLdScripts = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={pageUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- JSON-LD -->
    {
      jsonLdScripts.map((data) => (
        <script type="application/ld+json" set:html={JSON.stringify(data)} />
      ))
    }

    <!-- Google AdSense -->
    {
      adsenseClient && (
        <script
          async
          src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`}
          crossorigin="anonymous"
        />
      )
    }

    <!-- Google Analytics 4 -->
    {
      ga4Id && (
        <>
          <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`} />
          <script
            define:vars={{ ga4Id }}
            set:html={`
              window.dataLayer = window.dataLayer || [];
              function gtag(){dataLayer.push(arguments);}
              gtag('js', new Date());
              gtag('config', '${ga4Id}');
            `}
          />
        </>
      )
    }
  </head>
  <body class="min-h-screen flex flex-col bg-white text-slate-900">
    <header class="border-b border-slate-200">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <nav class="flex items-center justify-between h-16" aria-label="Main navigation">
          <a href="/" class="text-xl font-bold text-primary-700">Password Generator</a>
          <ul class="flex items-center gap-6 text-sm font-medium">
            <li><a href="/" class="hover:text-primary-600 transition-colors">Home</a></li>
            <li><a href="/tools/" class="hover:text-primary-600 transition-colors">Tools</a></li>
            <li><a href="/about/" class="hover:text-primary-600 transition-colors">About</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-slate-200 bg-slate-50">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-slate-600">
          <p>&copy; {new Date().getFullYear()} Password Generator. All rights reserved.</p>
          <ul class="flex items-center gap-6">
            <li><a href="/" class="hover:text-primary-600 transition-colors">Home</a></li>
            <li><a href="/tools/" class="hover:text-primary-600 transition-colors">Tools</a></li>
            <li><a href="/about/" class="hover:text-primary-600 transition-colors">About</a></li>
          </ul>
        </div>
      </div>
    </footer>
  </body>
</html>
