---
import ToolLayout from '../../components/ToolLayout.astro';
import PasswordTool from '../../components/PasswordTool.astro';
import AdSense from '../../components/AdSense.astro';
import AffiliateLink from '../../components/AffiliateLink.astro';

const title = 'Password Generator — Free & Secure Online Tool';
const description = 'Generate strong, random, and secure passwords instantly. Customize length, character types, and avoid ambiguous characters. Free and privacy-friendly.';
const canonical = `${Astro.site?.toString().replace(/\/$/, '') ?? 'https://passwordgenerator.example.com'}/tools/password-generator/`;
const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT ?? 'ca-pub-XXXXXXXXXXXXXXXX';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Password Generator',
  applicationCategory: 'SecurityApplication',
  operatingSystem: 'Any',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  description,
  url: canonical,
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.8',
    ratingCount: '124',
  },
};
---

<ToolLayout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <AdSense client={adsenseClient} adSlot="1234567890" format="horizontal" className="mb-8" />

  <PasswordTool>
    <div slot="after-output" class="rounded-2xl border border-slate-200 bg-slate-50 p-6 dark:border-slate-800 dark:bg-slate-900">
      <h2 class="text-lg font-semibold text-slate-900 mb-3 dark:text-slate-100">Keep your passwords safe</h2>
      <p class="text-slate-600 mb-4 dark:text-slate-400">
        Generated passwords are never sent to a server. For extra security, store them in a trusted password manager.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <AffiliateLink href="https://1password.com/" label="Try 1Password" />
        <AffiliateLink href="https://bitwarden.com/" label="Try Bitwarden" />
        <AffiliateLink href="https://www.lastpass.com/" label="Try LastPass" />
      </div>
    </div>
  </PasswordTool>

  <AdSense client={adsenseClient} adSlot="0987654321" format="rectangle" className="mt-8" />

  <section class="mt-12 prose prose-slate max-w-none">
    <h2 class="dark:text-slate-100">How to use this password generator</h2>
    <p>
      Choose a length between 8 and 128 characters, select the character sets you want, and click <strong class="dark:text-slate-100">Generate</strong>.
      Use the strength indicator to make sure your password is strong enough for the account you are protecting.
    </p>
    <h2 class="dark:text-slate-100">Why use a password generator?</h2>
    <p>
      Humans are bad at creating truly random passwords. A generator uses a cryptographically secure random number generator
      to create passwords that are hard to guess and resistant to brute-force attacks.
    </p>
    <h2 class="dark:text-slate-100">Tips for better security</h2>
    <ul>
      <li>Use at least 16 characters for important accounts.</li>
      <li>Include uppercase, lowercase, numbers, and symbols.</li>
      <li>Use a unique password for every account.</li>
      <li>Store passwords in a reputable password manager.</li>
    </ul>
  </section>
</ToolLayout>
