---
import ToolLayout from '../../components/ToolLayout.astro';
import PasswordTool from '../../components/PasswordTool.astro';
import AdSense from '../../components/AdSense.astro';
import AffiliateLink from '../../components/AffiliateLink.astro';

const title = 'Secure Password Generator — Private & Encrypted Locally';
const description = 'Generate secure passwords locally in your browser. No network requests, no tracking, and no stored data. Copy and use instantly.';
const canonical = `${Astro.site?.toString().replace(/\/$/, '') ?? 'https://passwordgenerator.example.com'}/tools/secure-password-generator/`;
const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT ?? 'ca-pub-XXXXXXXXXXXXXXXX';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Secure Password Generator',
  applicationCategory: 'SecurityApplication',
  operatingSystem: 'Any',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  description,
  url: canonical,
};
---

<ToolLayout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <AdSense client={adsenseClient} adSlot="4455667788" format="horizontal" className="mb-8" />

  <PasswordTool>
    <div slot="after-output" class="rounded-2xl border border-slate-200 bg-slate-50 p-6 dark:border-slate-800 dark:bg-slate-900">
      <h2 class="text-lg font-semibold text-slate-900 mb-3 dark:text-slate-100">Security starts with your password</h2>
      <p class="text-slate-600 mb-4 dark:text-slate-400">
        Secure passwords are generated on your device and never transmitted. Use a password manager to keep them organized and safe.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <AffiliateLink href="https://1password.com/" label="Secure with 1Password" />
        <AffiliateLink href="https://bitwarden.com/" label="Secure with Bitwarden" />
        <AffiliateLink href="https://www.lastpass.com/" label="Secure with LastPass" />
      </div>
    </div>
  </PasswordTool>

  <AdSense client={adsenseClient} adSlot="8877665544" format="rectangle" className="mt-8" />

  <section class="mt-12 prose prose-slate max-w-none">
    <h2 class="dark:text-slate-100">Is this password generator secure?</h2>
    <p>
      Yes. All generation happens inside your browser. The password is not sent to any server, logged, or stored unless you copy it yourself.
    </p>
    <h2 class="dark:text-slate-100">Best practices for secure passwords</h2>
    <ul>
      <li>Use a unique password for every service.</li>
      <li>Prefer 16+ characters with mixed character types.</li>
      <li>Enable two-factor authentication whenever possible.</li>
      <li>Store credentials in an audited password manager.</li>
    </ul>
  </section>
</ToolLayout>
