---
import ToolLayout from '../../components/ToolLayout.astro';
import PasswordTool from '../../components/PasswordTool.astro';
import AdSense from '../../components/AdSense.astro';
import AffiliateLink from '../../components/AffiliateLink.astro';

const title = 'WiFi Password Generator — Secure Router & Guest Network Passwords';
const description = 'Create strong WiFi passwords for your home router, guest network, and office access points. Long, random, and easy to share.';
const canonical = `${Astro.site?.toString().replace(/\/$/, '') ?? 'https://passgensecure.com'}/tools/wifi-password-generator/`;
const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT ?? 'ca-pub-XXXXXXXXXXXXXXXX';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'WiFi Password Generator',
  applicationCategory: 'SecurityApplication',
  operatingSystem: 'Any',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  description,
  url: canonical,
};

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How long should a WiFi password be?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A WiFi password should be at least 20 characters long. Longer passwords are better, especially for WPA2 and WPA3 networks.',
      },
    },
    {
      '@type': 'Question',
      name: 'Should I have a separate password for guest WiFi?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. A separate guest network isolates visitors from your main devices and lets you change the password without affecting your own network.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I use symbols in a WiFi password?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Most modern routers support symbols, but some older devices struggle with special characters. If you experience connection issues, use a long alphanumeric password instead.',
      },
    },
  ],
};
---

<ToolLayout title={title} description={description} canonical={canonical} jsonLd={[jsonLd, faqJsonLd]}>
  <AdSense client={adsenseClient} adSlot="5555555555" format="horizontal" className="mb-8" />

  <section class="prose prose-slate max-w-none mb-8">
    <p>
      Your WiFi network is the front door to your digital life. Once someone connects to it, they can potentially access your computers, phones, smart devices, and even intercept unencrypted traffic. That is why a strong WiFi password is one of the simplest and most effective home security upgrades you can make.
    </p>
    <p>
      Many routers ship with default passwords that are printed on a sticker or generated from a predictable algorithm. These default credentials are often leaked online or easy to guess. Changing your WiFi password to a long, random string is a basic step that dramatically reduces the risk of unauthorized access.
    </p>
    <p>
      This WiFi password generator helps you create passwords that are ideal for WPA2 and WPA3 networks. We recommend a length of at least 20 characters with a mix of uppercase, lowercase, numbers, and symbols. If you plan to share the password verbally with guests, you may prefer the <strong>avoid ambiguous characters</strong> option to prevent confusion between similar-looking characters like <code>0</code> and <code>O</code>.
    </p>
    <h3>How to use this tool for WiFi passwords</h3>
    <p>
      Set the length slider to 20 or more characters. Enable uppercase, lowercase, numbers, and symbols. Click <strong>Generate</strong> until you see a password you are comfortable sharing or storing. Copy it and paste it directly into your router's admin panel under wireless security settings. Remember to save the new password and reconnect all your devices.
    </p>
  </section>

  <PasswordTool>
    <div slot="after-output" class="rounded-2xl border border-slate-200 bg-slate-50 p-6 dark:border-slate-800 dark:bg-slate-900">
      <h2 class="text-lg font-semibold text-slate-900 mb-3 dark:text-slate-100">Secure your whole network</h2>
      <p class="text-slate-600 mb-4 dark:text-slate-400">
        A strong WiFi password is just one layer. Consider a password manager to store network credentials and router logins safely.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <AffiliateLink href="https://1password.com/" label="Try 1Password" />
        <AffiliateLink href="https://bitwarden.com/" label="Try Bitwarden" />
      </div>
    </div>
  </PasswordTool>

  <AdSense client={adsenseClient} adSlot="6666666666" format="rectangle" className="mt-8" />

  <section class="mt-12 prose prose-slate max-w-none">
    <h2>WiFi password tips</h2>
    <ul>
      <li>Use at least 20 characters for WPA2/WPA3 networks.</li>
      <li>Change the default admin password on your router, not just the WiFi password.</li>
      <li>Create a separate guest network with a different password.</li>
      <li>Use WPA3 if your router supports it; otherwise use WPA2.</li>
      <li>Disable WPS, which has known security weaknesses.</li>
    </ul>

    <h2>Frequently asked questions</h2>
    <h3>How long should a WiFi password be?</h3>
    <p>A WiFi password should be at least 20 characters long. Longer passwords are better, especially for WPA2 and WPA3 networks.</p>

    <h3>Should I have a separate password for guest WiFi?</h3>
    <p>Yes. A separate guest network isolates visitors from your main devices and lets you change the password without affecting your own network.</p>

    <h3>Can I use symbols in a WiFi password?</h3>
    <p>Most modern routers support symbols, but some older devices struggle with special characters. If you experience connection issues, use a long alphanumeric password instead.</p>
  </section>
</ToolLayout>
