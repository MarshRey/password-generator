---
import ToolLayout from '../../components/ToolLayout.astro';
import PasswordTool from '../../components/PasswordTool.astro';
import AdSense from '../../components/AdSense.astro';
import AffiliateLink from '../../components/AffiliateLink.astro';

const title = 'Random Password Generator — Truly Random & Secure';
const description = 'Generate truly random passwords using your browser\'s cryptographically secure random number generator. Customize length and character sets. No data leaves your device.';
const canonical = `${Astro.site?.toString().replace(/\/$/, '') ?? 'https://passgensecure.com'}/tools/random-password-generator/`;
const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT ?? 'ca-pub-XXXXXXXXXXXXXXXX';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Random Password Generator',
  applicationCategory: 'SecurityApplication',
  operatingSystem: 'Any',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  description,
  url: canonical,
};
---

<ToolLayout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <AdSense client={adsenseClient} adSlot="3344556677" format="horizontal" className="mb-8" />

  <PasswordTool>
    <div slot="after-output" class="rounded-2xl border border-slate-200 bg-slate-50 p-6 dark:border-slate-800 dark:bg-slate-900">
      <h2 class="text-lg font-semibold text-slate-900 mb-3 dark:text-slate-100">Randomness you can trust</h2>
      <p class="text-slate-600 mb-4 dark:text-slate-400">
        This generator uses the browser's built-in crypto API for randomness. Pair it with a password manager for the best security.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <AffiliateLink href="https://1password.com/" label="Try 1Password" />
        <AffiliateLink href="https://bitwarden.com/" label="Try Bitwarden" />
        <AffiliateLink href="https://www.lastpass.com/" label="Try LastPass" />
      </div>
    </div>
  </PasswordTool>

  <AdSense client={adsenseClient} adSlot="7766554433" format="rectangle" className="mt-8" />

  <section class="mt-12 prose prose-slate max-w-none">
    <h2 class="dark:text-slate-100">What is a random password?</h2>
    <p>
      A random password is one created by a random process rather than by a person. Random passwords are harder to crack
      because they do not contain predictable words, dates, or patterns.
    </p>
    <h2 class="dark:text-slate-100">Is it really random?</h2>
    <p>
      Yes. The tool uses <code class="dark:bg-slate-800">window.crypto.getRandomValues</code>, the same source of randomness trusted by modern browsers for HTTPS.
    </p>
  </section>
</ToolLayout>
