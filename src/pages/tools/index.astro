---
import ToolLayout from '../../components/ToolLayout.astro';

const title = 'Tools — Password Generator';
const description = 'Browse free password tools. Generate strong, random, and secure passwords instantly.';

const tools = [
  {
    title: 'Password Generator',
    description: 'Generate customizable, secure passwords with entropy-based strength feedback.',
    href: '/tools/password-generator/',
  },
  {
    title: 'Strong Password Generator',
    description: 'Create long, unbreakable passwords for your most important accounts.',
    href: '/tools/strong-password-generator/',
  },
  {
    title: 'Random Password Generator',
    description: 'Generate truly random passwords using your browser\'s crypto API.',
    href: '/tools/random-password-generator/',
  },
  {
    title: 'Secure Password Generator',
    description: 'Generate passwords locally with no server requests or tracking.',
    href: '/tools/secure-password-generator/',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: title,
  itemListElement: tools.map((tool, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    url: tool.href,
    name: tool.title,
  })),
};
---

<ToolLayout title={title} description={description} jsonLd={jsonLd}>
  <p class="text-slate-600 mb-8">
    All tools run in your browser. No passwords are sent to or stored on our servers.
  </p>

  <ul class="grid gap-4 sm:grid-cols-2">
    {
      tools.map((tool) => (
        <li>
          <a
            href={tool.href}
            class="block rounded-xl border border-slate-200 bg-white p-6 shadow-sm hover:shadow-md hover:border-primary-300 transition-all"
          >
            <h2 class="text-lg font-semibold text-slate-900">{tool.title}</h2>
            <p class="mt-2 text-slate-600">{tool.description}</p>
          </a>
        </li>
      ))
    }
  </ul>
</ToolLayout>
