---
import ToolLayout from '../../components/ToolLayout.astro';
import PasswordTool from '../../components/PasswordTool.astro';
import AdSense from '../../components/AdSense.astro';
import AffiliateLink from '../../components/AffiliateLink.astro';

const title = 'Temporary Password Generator — One-Time & Shared Credentials';
const description = 'Generate temporary passwords for one-time access, shared accounts, guest logins, and short-term projects. Secure, local, and fast.';
const canonical = `${Astro.site?.toString().replace(/\/$/, '') ?? 'https://passgensecure.com'}/tools/temporary-password-generator/`;
const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT ?? 'ca-pub-XXXXXXXXXXXXXXXX';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Temporary Password Generator',
  applicationCategory: 'SecurityApplication',
  operatingSystem: 'Any',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  description,
  url: canonical,
};

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is a temporary password?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A temporary password is a credential meant for short-term use. It is commonly used for one-time logins, guest access, shared accounts, or password resets.',
      },
    },
    {
      '@type': 'Question',
      name: 'How long should a temporary password be?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Even for short-term use, a temporary password should be at least 12–16 characters long with mixed character types. Short credentials are easier to guess or intercept.',
      },
    },
    {
      '@type': 'Question',
      name: 'How do I share a temporary password securely?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Share it through an encrypted messaging app, a password manager sharing feature, or a self-destructing note service. Avoid email and unencrypted chat.',
      },
    },
  ],
};
---

<ToolLayout title={title} description={description} canonical={canonical} jsonLd={[jsonLd, faqJsonLd]}>
  <AdSense client={adsenseClient} adSlot="9999999999" format="horizontal" className="mb-8" />

  <section class="prose prose-slate max-w-none mb-8">
    <p>
      Not every password needs to last forever. Sometimes you need a credential for a single event, a short-term contractor, a guest login, or a shared account that will be retired in a few days. A <strong>temporary password</strong> is the right tool for these situations. It should be strong enough to resist guessing during its short lifetime, and it should be changed or revoked as soon as it is no longer needed.
    </p>
    <p>
      Temporary passwords are common in IT support workflows. When a user forgets their password, an administrator may generate a temporary credential and require the user to change it on first login. Event organizers use temporary WiFi or app passwords for attendees. Freelancers may receive temporary access to client tools for the duration of a project.
    </p>
    <p>
      Use this generator to create a secure temporary password in seconds. Set the length to at least 16 characters and enable all character types. Copy the result and share it through a secure channel. If the password will be read aloud, check the <strong>avoid ambiguous characters</strong> option to reduce mistakes.
    </p>
    <h3>Important security note</h3>
    <p>
      A temporary password is only secure if it is actually temporary. Set an expiration time, communicate it clearly, and disable or change the password promptly. Treat temporary credentials with the same care as permanent ones while they are active.
    </p>
  </section>

  <PasswordTool>
    <div slot="after-output" class="rounded-2xl border border-slate-200 bg-slate-50 p-6 dark:border-slate-800 dark:bg-slate-900">
      <h2 class="text-lg font-semibold text-slate-900 mb-3 dark:text-slate-100">Share credentials safely</h2>
      <p class="text-slate-600 mb-4 dark:text-slate-400">
        Use a password manager with secure sharing for temporary or guest credentials.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <AffiliateLink href="https://1password.com/" label="Try 1Password" />
        <AffiliateLink href="https://bitwarden.com/" label="Try Bitwarden" />
      </div>
    </div>
  </PasswordTool>

  <AdSense client={adsenseClient} adSlot="1010101010" format="rectangle" className="mt-8" />

  <section class="mt-12 prose prose-slate max-w-none">
    <h2>Temporary password tips</h2>
    <ul>
      <li>Set a clear expiration time before sharing.</li>
      <li>Use at least 16 characters even for short-term credentials.</li>
      <li>Require the user to change the password on first login when possible.</li>
      <li>Disable the account or reset the password as soon as access is no longer needed.</li>
      <li>Avoid reusing temporary passwords for different people or events.</li>
    </ul>

    <h2>Frequently asked questions</h2>
    <h3>What is a temporary password?</h3>
    <p>A temporary password is a credential meant for short-term use. It is commonly used for one-time logins, guest access, shared accounts, or password resets.</p>

    <h3>How long should a temporary password be?</h3>
    <p>Even for short-term use, a temporary password should be at least 12–16 characters long with mixed character types. Short credentials are easier to guess or intercept.</p>

    <h3>How do I share a temporary password securely?</h3>
    <p>Share it through an encrypted messaging app, a password manager sharing feature, or a self-destructing note service. Avoid email and unencrypted chat.</p>
  </section>
</ToolLayout>
