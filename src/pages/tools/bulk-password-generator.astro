---
import ToolLayout from '../../components/ToolLayout.astro';
import PasswordTool from '../../components/PasswordTool.astro';
import AdSense from '../../components/AdSense.astro';
import AffiliateLink from '../../components/AffiliateLink.astro';

const title = 'Bulk Password Generator — Create Many Passwords for Teams & IT Admins';
const description = 'Generate multiple strong, unique passwords at once. Ideal for IT administrators, onboarding, and provisioning shared accounts.';
const canonical = `${Astro.site?.toString().replace(/\/$/, '') ?? 'https://passwordgenerator.example.com'}/tools/bulk-password-generator/`;
const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT ?? 'ca-pub-XXXXXXXXXXXXXXXX';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Bulk Password Generator',
  applicationCategory: 'SecurityApplication',
  operatingSystem: 'Any',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  description,
  url: canonical,
};

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Can I generate multiple passwords at once?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'This page uses the standard password generator. Click Generate repeatedly to create as many unique passwords as you need, then copy them individually.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is bulk password generation safe?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes, because passwords are generated locally in your browser and never sent to our servers. They remain private until you copy or export them.',
      },
    },
    {
      '@type': 'Question',
      name: 'How should IT teams distribute generated passwords?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Use a secure channel such as an enterprise password manager or encrypted messaging. Avoid email, chat logs, or plain text documents.',
      },
    },
  ],
};
---

<ToolLayout title={title} description={description} canonical={canonical} jsonLd={[jsonLd, faqJsonLd]}>
  <AdSense client={adsenseClient} adSlot="7777777777" format="horizontal" className="mb-8" />

  <section class="prose prose-slate max-w-none mb-8">
    <p>
      IT administrators and security teams often need to create many strong, unique passwords in a short amount of time. Whether you are onboarding a batch of new employees, resetting credentials after a security incident, or provisioning service accounts, manually inventing passwords is slow and risky. A <strong>bulk password generator</strong> approach helps you produce high-entropy credentials consistently.
    </p>
    <p>
      This page uses our standard secure password generator. To create multiple passwords, simply click <strong>Generate</strong> as many times as needed. Each result is produced locally in your browser using the Web Crypto API, so nothing is transmitted over the network. Copy each password into your password manager, onboarding spreadsheet, or identity management system.
    </p>
    <p>
      For bulk workflows, we recommend configuring the generator to match your organization's policy. Set a minimum length of 16 characters, enable all character types, and consider checking the <strong>avoid ambiguous characters</strong> option if passwords will be read aloud or typed manually by end users.
    </p>
    <h3>Enterprise considerations</h3>
    <p>
      When generating credentials at scale, distribution is just as important as generation. Share passwords through secure, auditable channels such as an enterprise password manager or privileged access management (PAM) platform. Avoid sending passwords over email or storing them in unencrypted documents. Rotate credentials regularly and revoke access immediately when employees leave.
    </p>
  </section>

  <PasswordTool>
    <div slot="after-output" class="rounded-2xl border border-slate-200 bg-slate-50 p-6 dark:border-slate-800 dark:bg-slate-900">
      <h2 class="text-lg font-semibold text-slate-900 mb-3 dark:text-slate-100">Manage passwords at scale</h2>
      <p class="text-slate-600 mb-4 dark:text-slate-400">
        For teams, a business password manager makes bulk credential management safer and easier.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <AffiliateLink href="https://1password.com/" label="Try 1Password Business" />
        <AffiliateLink href="https://bitwarden.com/" label="Try Bitwarden Enterprise" />
      </div>
    </div>
  </PasswordTool>

  <AdSense client={adsenseClient} adSlot="8888888888" format="rectangle" className="mt-8" />

  <section class="mt-12 prose prose-slate max-w-none">
    <h2>Bulk password tips</h2>
    <ul>
      <li>Generate each password fresh rather than copying a template.</li>
      <li>Use a minimum length of 16 characters for employee accounts.</li>
      <li>Enable symbols and numbers unless an old system restricts them.</li>
      <li>Document which account each password belongs to in a secure vault.</li>
      <li>Rotate credentials on a schedule or immediately after suspected compromise.</li>
    </ul>

    <h2>Frequently asked questions</h2>
    <h3>Can I generate multiple passwords at once?</h3>
    <p>This page uses the standard password generator. Click Generate repeatedly to create as many unique passwords as you need, then copy them individually.</p>

    <h3>Is bulk password generation safe?</h3>
    <p>Yes, because passwords are generated locally in your browser and never sent to our servers. They remain private until you copy or export them.</p>

    <h3>How should IT teams distribute generated passwords?</h3>
    <p>Use a secure channel such as an enterprise password manager or encrypted messaging. Avoid email, chat logs, or plain text documents.</p>
  </section>
</ToolLayout>
