---
import ToolLayout from '../../components/ToolLayout.astro';
import PasswordTool from '../../components/PasswordTool.astro';
import AdSense from '../../components/AdSense.astro';
import AffiliateLink from '../../components/AffiliateLink.astro';

const title = 'Strong Password Generator — Create Unbreakable Passwords';
const description = 'Create strong passwords with uppercase, lowercase, numbers, and symbols. Adjust length, check entropy, and copy instantly. Free and private.';
const canonical = `${Astro.site?.toString().replace(/\/$/, '') ?? 'https://passwordgenerator.example.com'}/tools/strong-password-generator/`;
const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT ?? 'ca-pub-XXXXXXXXXXXXXXXX';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Strong Password Generator',
  applicationCategory: 'SecurityApplication',
  operatingSystem: 'Any',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  description,
  url: canonical,
};
---

<ToolLayout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <AdSense client={adsenseClient} adSlot="2233445566" format="horizontal" className="mb-8" />

  <PasswordTool>
    <div slot="after-output" class="rounded-2xl border border-slate-200 bg-slate-50 p-6 dark:border-slate-800 dark:bg-slate-900">
      <h2 class="text-lg font-semibold text-slate-900 mb-3 dark:text-slate-100">Make every password strong</h2>
      <p class="text-slate-600 mb-4 dark:text-slate-400">
        A strong password is long, random, and unique. Use a password manager so you do not have to remember them all.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <AffiliateLink href="https://1password.com/" label="Get 1Password" />
        <AffiliateLink href="https://bitwarden.com/" label="Get Bitwarden" />
        <AffiliateLink href="https://www.lastpass.com/" label="Get LastPass" />
      </div>
    </div>
  </PasswordTool>

  <AdSense client={adsenseClient} adSlot="6655443322" format="rectangle" className="mt-8" />

  <section class="mt-12 prose prose-slate max-w-none">
    <h2 class="dark:text-slate-100">What makes a password strong?</h2>
    <p>
      Strength comes from length and unpredictability. The more possible combinations a password has, the longer it takes
      an attacker to guess. Our tool shows the entropy in bits so you can see exactly how strong your password is.
    </p>
    <h2 class="dark:text-slate-100">Recommended settings</h2>
    <ul>
      <li>Length: 16 characters or more</li>
      <li>All character types enabled</li>
      <li>Avoid ambiguous characters only if you need to type the password manually</li>
    </ul>
  </section>
</ToolLayout>
