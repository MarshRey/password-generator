---
import Layout from '../components/Layout.astro';
import AdSense from '../components/AdSense.astro';
import AffiliateLink from '../components/AffiliateLink.astro';
import PasswordTool from '../components/PasswordTool.astro';
import { Shield, Zap, Lock, EyeOff } from '@lucide/astro';

const title = 'Password Generator — Free Strong & Secure Passwords';
const description = 'Generate strong, random, and secure passwords for free. Customize length and character types, check entropy, and copy with one click. No sign-up required.';
const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT ?? 'ca-pub-XXXXXXXXXXXXXXXX';

const features = [
  {
    icon: Shield,
    title: 'Cryptographically Secure',
    description: 'Uses your browser\'s built-in crypto API for true randomness.',
  },
  {
    icon: Zap,
    title: 'Instant Generation',
    description: 'Generate and copy passwords in milliseconds, right in your browser.',
  },
  {
    icon: Lock,
    title: 'Privacy First',
    description: 'No passwords are sent to our servers or stored anywhere.',
  },
  {
    icon: EyeOff,
    title: 'No Sign-up',
    description: 'Use the tool anonymously without creating an account.',
  },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Password Generator',
    url: Astro.site?.toString() ?? 'https://passgensecure.com',
    description,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Password Generator',
    applicationCategory: 'SecurityApplication',
    operatingSystem: 'Any',
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
    },
    description,
    url: `${Astro.site?.toString().replace(/\/$/, '') ?? 'https://passgensecure.com'}/tools/password-generator/`,
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.8',
      ratingCount: '124',
    },
  },
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <section class="bg-gradient-to-b from-primary-50 to-white py-12 sm:py-16 dark:from-primary-950/30 dark:to-slate-950">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-slate-900 dark:text-slate-100">
        Free Password Generator
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
        Create strong, random, and secure passwords in seconds. No tracking, no sign-up, and no data sent to our servers.
      </p>
    </div>
  </section>

  <section class="pb-12 sm:pb-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <AdSense client={adsenseClient} adSlot="1111111111" format="horizontal" className="mb-8" />

      <PasswordTool>
        <div slot="after-output" class="rounded-2xl border border-slate-200 bg-slate-50 p-6 dark:border-slate-800 dark:bg-slate-900">
          <h2 class="text-lg font-semibold text-slate-900 mb-3 dark:text-slate-100">Keep your passwords safe</h2>
          <p class="text-slate-600 mb-4 dark:text-slate-400">
            Generated passwords are never sent to a server. For extra security, store them in a trusted password manager.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <AffiliateLink href="https://1password.com/" label="Try 1Password" />
            <AffiliateLink href="https://bitwarden.com/" label="Try Bitwarden" />
            <AffiliateLink href="https://www.lastpass.com/" label="Try LastPass" />
          </div>
        </div>
      </PasswordTool>

      <AdSense client={adsenseClient} adSlot="1234567891" format="rectangle" className="mt-8" />
    </div>
  </section>

  <section class="py-16 sm:py-20 border-t border-slate-200 dark:border-slate-800">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {
          features.map((feature) => (
            <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm hover:shadow-md transition-shadow dark:border-slate-800 dark:bg-slate-900">
              <div class="mb-4 inline-flex items-center justify-center rounded-lg bg-primary-100 p-3 text-primary-700 dark:bg-primary-900/40 dark:text-primary-400">
                <feature.icon size={24} />
              </div>
              <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">{feature.title}</h3>
              <p class="mt-2 text-slate-600 dark:text-slate-400">{feature.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="border-t border-slate-200 bg-slate-50 py-16 dark:border-slate-800 dark:bg-slate-900">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-slate-100">Guides & resources</h2>
        <p class="mt-4 text-slate-600 dark:text-slate-400">Learn how to create, manage, and protect your passwords.</p>
      </div>
      <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <li>
          <a href="/blog/how-to-create-a-strong-password/" class="block rounded-xl border border-slate-200 bg-white p-6 shadow-sm hover:shadow-md hover:border-primary-300 transition-all dark:border-slate-800 dark:bg-slate-900 dark:hover:border-primary-700">
            <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">How to Create a Strong Password</h3>
            <p class="mt-2 text-slate-600 dark:text-slate-400">A complete guide to building unbreakable credentials.</p>
          </a>
        </li>
        <li>
          <a href="/blog/password-manager-buying-guide/" class="block rounded-xl border border-slate-200 bg-white p-6 shadow-sm hover:shadow-md hover:border-primary-300 transition-all dark:border-slate-800 dark:bg-slate-900 dark:hover:border-primary-700">
            <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Password Manager Buying Guide</h3>
            <p class="mt-2 text-slate-600 dark:text-slate-400">Find the right manager for personal or business use.</p>
          </a>
        </li>
        <li>
          <a href="/blog/what-makes-a-password-secure/" class="block rounded-xl border border-slate-200 bg-white p-6 shadow-sm hover:shadow-md hover:border-primary-300 transition-all dark:border-slate-800 dark:bg-slate-900 dark:hover:border-primary-700">
            <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">What Makes a Password Secure</h3>
            <p class="mt-2 text-slate-600 dark:text-slate-400">Entropy, length, and randomness explained.</p>
          </a>
        </li>
        <li>
          <a href="/blog/common-password-mistakes/" class="block rounded-xl border border-slate-200 bg-white p-6 shadow-sm hover:shadow-md hover:border-primary-300 transition-all dark:border-slate-800 dark:bg-slate-900 dark:hover:border-primary-700">
            <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Common Password Mistakes</h3>
            <p class="mt-2 text-slate-600 dark:text-slate-400">Fix these habits before your next breach.</p>
          </a>
        </li>
        <li>
          <a href="/blog/password-vs-passphrase/" class="block rounded-xl border border-slate-200 bg-white p-6 shadow-sm hover:shadow-md hover:border-primary-300 transition-all dark:border-slate-800 dark:bg-slate-900 dark:hover:border-primary-700">
            <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Password vs Passphrase</h3>
            <p class="mt-2 text-slate-600 dark:text-slate-400">Choose the right credential for every account.</p>
          </a>
        </li>
      </ul>
      <div class="mt-8 text-center">
        <a href="/blog/" class="inline-flex items-center justify-center rounded-lg bg-white px-6 py-3 text-base font-semibold text-primary-700 shadow-sm ring-1 ring-slate-200 hover:bg-slate-50 transition-colors dark:bg-slate-900 dark:text-primary-400 dark:ring-slate-700 dark:hover:bg-slate-800">View all guides</a>
      </div>
    </div>
  </section>

  <section class="border-t border-slate-200 bg-white py-16 dark:border-slate-800 dark:bg-slate-950">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-slate-100">Never reuse a password again</h2>
      <p class="mt-4 text-slate-600 dark:text-slate-400">
        Generate unique passwords for every account and store them safely with a trusted password manager.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-6">
        <div class="flex flex-col sm:flex-row items-center gap-4">
          <AffiliateLink href="https://1password.com/" label="1Password" />
          <AffiliateLink href="https://bitwarden.com/" label="Bitwarden" />
          <AffiliateLink href="https://www.lastpass.com/" label="LastPass" />
        </div>
      </div>
      <p class="mt-4 text-xs text-slate-500 dark:text-slate-500">Affiliate links — we may earn a commission at no extra cost to you.</p>
    </div>
  </section>
</Layout>
