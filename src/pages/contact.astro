---
import ToolLayout from '../components/ToolLayout.astro';

const title = 'Contact Us — Password Generator';
const description = 'Get in touch with Password Generator. Send questions, feedback, or partnership inquiries through our contact form.';
const canonical = `${Astro.site?.toString().replace(/\/$/, '') ?? 'https://passgensecure.com'}/contact/`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: title,
  description,
  url: canonical,
};
---

<ToolLayout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <div class="prose prose-slate max-w-none">
    <p>
      Have a question, suggestion, or business inquiry? Fill out the form below and we will get back to you as soon as possible. We typically respond within 2–3 business days.
    </p>

    <form
      action="mailto:support@passgensecure.com"
      method="post"
      enctype="text/plain"
      class="mt-8 space-y-6 not-prose rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900"
    >
      <div>
        <label for="name" class="block text-sm font-medium text-slate-700 dark:text-slate-300">Name</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          class="mt-2 block w-full rounded-lg border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100 dark:focus:ring-primary-900"
        />
      </div>

      <div>
        <label for="email" class="block text-sm font-medium text-slate-700 dark:text-slate-300">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="mt-2 block w-full rounded-lg border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100 dark:focus:ring-primary-900"
        />
      </div>

      <div>
        <label for="subject" class="block text-sm font-medium text-slate-700 dark:text-slate-300">Subject</label>
        <select
          id="subject"
          name="subject"
          class="mt-2 block w-full rounded-lg border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100 dark:focus:ring-primary-900"
        >
          <option value="General question">General question</option>
          <option value="Feature request">Feature request</option>
          <option value="Bug report">Bug report</option>
          <option value="Partnership / Affiliate">Partnership / Affiliate</option>
          <option value="Other">Other</option>
        </select>
      </div>

      <div>
        <label for="message" class="block text-sm font-medium text-slate-700 dark:text-slate-300">Message</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          class="mt-2 block w-full rounded-lg border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 outline-none dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100 dark:focus:ring-primary-900"
        ></textarea>
      </div>

      <button
        type="submit"
        class="inline-flex items-center justify-center rounded-lg bg-primary-600 px-6 py-3 text-base font-semibold text-white hover:bg-primary-700 transition-colors"
      >
        Send Message
      </button>

      <p class="text-sm text-slate-500 dark:text-slate-500">
        This form opens your email client. No data is sent through our servers.
      </p>
    </form>

    <h2>Response times</h2>
    <p>
      We read every message and aim to respond within 2–3 business days. Messages sent on weekends or holidays may take a little longer. For urgent security issues, please include “Security” in the subject line.
    </p>

    <h2>Partnership inquiries</h2>
    <p>
      Interested in affiliate partnerships, sponsored content, or collaboration? Let us know in your message and we will follow up with details.
    </p>
  </div>
</ToolLayout>
